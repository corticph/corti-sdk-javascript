# Specify files that shouldn't be modified by Fern

# Documentation — hand-maintained, not generated
README.md
reference.md

# Custom code (not generated by Fern)
src/custom/

# Thin re-export wrapper — all exports consolidated in src/custom/index.ts
src/index.ts

# Thin re-export wrapper — custom logic lives in src/custom/OAuthAuthProvider.ts
src/auth/OAuthAuthProvider.ts

# Fetcher barrel re-exports from custom/ where fetcher injects global withCredentials default.
src/core/fetcher/index.ts

# Wire tests authentication
tests/wire/mockAuth.ts

# Integration tests — hand-maintained, not generated
tests/custom/

# Integration test vitest config
vitest.integration.config.mts

# CI/release workflows and GitHub config — hand-maintained, Fern must not overwrite
.github/
